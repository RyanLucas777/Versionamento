algoritmo "Menu da Lanchonete"

var
codigo: inteiro
total: real

inicio

total <- 0

repita

  escreval(" MENU DA LANCHONETE ")
  escreval("1-Cachorro Quente R$ 8,00")
  escreval("2-Hambúrguer R$ 15,00")
  escreval("3-Misto Quente R$ 10,00")
  escreval("4-Refrigerante R$ 5,00")
  escreval("5-Encerrar Pedido")
  escreval("                    ")

  escreva("Digite o número do item: ")
  leia(codigo)

  escolha codigo

    caso 1
      escreval("            ")
      escreval("Item selecionado: Cachorro Quente - R$ 8")
      total <- total + 8

    caso 2
      escreval("            ")
      escreval("Item selecionado: Hambúrguer - R$ 15")
      total <- total + 15

    caso 3
      escreval("            ")
      escreval("Item selecionado: Misto Quente - R$ 10")
      total <- total + 10

    caso 4
      escreval("            ")
      escreval("Item selecionado: Refrigerante - R$ 5")
      total <- total + 5

    caso 5
      escreval("            ")
      escreval("Pedido encerrado. Muito obrigado!")

    outrocaso
      escreval("            ")
      escreval("Código não existe!")

  fimescolha

  escreval(" ")

ate codigo = 5

escreval("Total da conta: R$ ", total:)

fimalgoritmo
